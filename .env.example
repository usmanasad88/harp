# Copy to .env and fill in. .env is gitignored.

# Google AI Studio key for Gemini Live API (https://aistudio.google.com/apikey)
# Free tier key:
GEMINI_API_KEY= ""

# OpenAI key for the OpenAI Realtime provider (added in a later chunk)
OPENAI_API_KEY= ""

# --- Realtime model / voice (optional) -------------------------------------
# Read by BOTH the web-realtime sandbox (server.js) and `python -m harp`, which
# load this same file. Set the model here once and the two stay in sync — e.g.
# switch to a mini model for cheap testing, then switch back.
#   precedence: OPENAI_MODEL > REALTIME_MODEL > built-in default
# REALTIME_MODEL=gpt-realtime-2       # full model  (mini for testing: gpt-realtime-mini)
# REALTIME_VOICE=marin
